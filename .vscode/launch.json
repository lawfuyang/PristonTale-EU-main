{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Login Server",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Files/Server/login-server/Server.exe",
            "cwd": "${workspaceFolder}/Files/Server/login-server",
            "args": [],
            "environment": [],
            "console": "integratedTerminal",
            "symbolSearchPath": "${workspaceFolder}/Files/Server/login-server;${workspaceFolder}/build/bin/Server/Debug"
        },
        {
            "name": "Game Server",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Files/Server/game-server/Server.exe",
            "cwd": "${workspaceFolder}/Files/Server/game-server",
            "args": [],
            "environment": [],
            "console": "integratedTerminal",
            "symbolSearchPath": "${workspaceFolder}/Files/Server/game-server;${workspaceFolder}/build/bin/Server/Debug"
        },
        {
            "name": "Game Client",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Files/Game/Game.exe",
            "cwd": "${workspaceFolder}/Files/Game",
            "args": [],
            "environment": [],
            "console": "integratedTerminal"
        },
        {
            "name": "▶ Run All (Login + Game Server + Client)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "C:/Windows/System32/WindowsPowerShell/v1.0/powershell.exe",
            "cwd": "${workspaceFolder}",
            "args": [
                "-NoLogo",
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/scripts/launch-all.ps1"
            ],
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "Ensure Docker SQL Running"
        },
        {
            "name": "▶ Run Servers Only (Login + Game)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "C:/Windows/System32/WindowsPowerShell/v1.0/powershell.exe",
            "cwd": "${workspaceFolder}",
            "args": [
                "-NoLogo",
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/scripts/launch-all.ps1",
                "-SkipClient"
            ],
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "Ensure Docker SQL Running"
        }
    ]
}
